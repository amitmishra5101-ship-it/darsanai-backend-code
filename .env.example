# ─────────────────────────────────────────────────────────────
# darsanai.AI — Environment Variables
# Copy this file to .env and fill in your real values
# Never commit .env to git!
# ─────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS) — change to your Vercel URL in production
FRONTEND_URL=http://localhost:5173

# ── RUNWAY API ────────────────────────────────────────────────
# Get your key at: https://app.runwayml.com/settings/api-keys
RUNWAY_API_KEY=your_runway_api_key_here
RUNWAY_API_BASE=https://api.runwayml.com/v1

# ── KLING API (optional fallback) ────────────────────────────
# Get your key at: https://klingai.com/developers
KLING_API_KEY=your_kling_api_key_here
KLING_API_BASE=https://api.klingai.com/v1

# ── REDIS (for job queue) ─────────────────────────────────────
# Local: redis://localhost:6379
# Production: get a free Redis from upstash.com
REDIS_URL=redis://localhost:6379

# ── AWS S3 (for video storage) ────────────────────────────────
# Create a free bucket at aws.amazon.com/s3
# Or use Cloudflare R2 (cheaper) — same API
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=darsanai-videos

# ── AUTH (Clerk) ──────────────────────────────────────────────
# Get your secret key at: https://clerk.com
CLERK_SECRET_KEY=your_clerk_secret_key

# ── INTERNAL API SECRET ───────────────────────────────────────
# Random string — used to secure internal routes
API_SECRET=change_this_to_a_random_secret_string_32_chars

# ── CREDIT COSTS ─────────────────────────────────────────────
CREDITS_PER_SECOND=2
FREE_TIER_CREDITS=20
